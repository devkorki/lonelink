# LAN Share — environment variables
# Copy this file to ".env" and edit the values you want.

# Optional simple password protection.
# Leave empty (or remove the line) to disable login entirely.
SHARE_PASSWORD=

# Port the server listens on. Default is 3000.
PORT=3000

# Maximum upload size, per file, in megabytes. Default is 500.
MAX_UPLOAD_SIZE_MB=500
